APP_BASE_URL=https://triptokforge.org

# Epic OAuth: fill these in after Epic approves the production domain.
EPIC_CLIENT_ID=YOUR_EPIC_CLIENT_ID_HERE
EPIC_CLIENT_SECRET=YOUR_EPIC_CLIENT_SECRET_HERE
EPIC_DEPLOYMENT_ID=YOUR_EPIC_DEPLOYMENT_ID_HERE

# Optional override. If omitted, the app uses APP_BASE_URL + /auth/callback.
# EPIC_REDIRECT_URI=https://triptokforge.org/auth/callback

FLASK_SECRET_KEY=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-long-random-password

# Oracle Autonomous DB
ORACLE_DSN=
ORACLE_USER=ADMIN
ORACLE_PASSWORD=
ORACLE_WALLET=

# OCI Object Storage
OCI_NAMESPACE=
OCI_BUCKET=triptokforge
OCI_REGION=us-ashburn-1
OCI_CONFIG_FILE=
