# ═══════════════════════════════════════════════════════════════
# EPG SCHEDULE GENERATOR
# Creates fake TV schedules (in real system, this comes from APIs)
# ═══════════════════════════════════════════════════════════════

def generate_epg_for_channel(channel_id, hours=12):
    """
    Generate EPG (schedule) for a channel
    
    Args:
        channel_id: Which channel
        hours: How many hours of schedule to generate
    
    Returns:
        List of programs with start/end times
    """
    
    # Program templates (what could be airing)
    news_programs = [
        {"title": "Breaking News Coverage", "duration": 60},
        {"title": "World News Tonight", "duration": 30},
        {"title": "Special Report", "duration": 45},
        {"title": "Live Press Conference", "duration": 90},
    ]
    
    schedule = []
    current_time = datetime.now().replace(minute=0, second=0, microsecond=0)
    end_time = current_time + timedelta(hours=hours)
    
    # Generate schedule by filling time slots
    while current_time < end_time:
        # Pick a random program
        import random
        program = random.choice(news_programs)
        
        # Calculate when it ends
        program_end = current_time + timedelta(minutes=program['duration'])
        
        schedule.append({
            "title": program['title'],
            "start": current_time.isoformat(),
            "end": program_end.isoformat(),
            "duration": program['duration'],
            "description": f"Live coverage on {CHANNELS[channel_id]['name']}"
        })
        
        current_time = program_end
    
    return schedule


# ═══════════════════════════════════════════════════════════════
# API ROUTES (What the frontend calls)
# ═══════════════════════════════════════════════════════════════

@channels_bp.route('/api/channels', methods=['GET'])
def get_channels():
    """
    GET /api/channels
    Returns: List of all channels
    """
    return jsonify({
        "channels": list(CHANNELS.values()),
        "total": len(CHANNELS)
    })


@channels_bp.route('/api/channels/<channel_id>', methods=['GET'])
def get_channel(channel_id):
    """
    GET /api/channels/abc_news
    Returns: Single channel details
    """
    if channel_id not in CHANNELS:
        return jsonify({"error": "Channel not found"}), 404
    
    return jsonify(CHANNELS[channel_id])


@channels_bp.route('/api/channels/<channel_id>/schedule', methods=['GET'])
def get_channel_schedule(channel_id):
    """
    GET /api/channels/abc_news/schedule
    Returns: What's playing on this channel (EPG data)
    """
    if channel_id not in CHANNELS:
        return jsonify({"error": "Channel not found"}), 404
    
    schedule = generate_epg_for_channel(channel_id, hours=12)
    
    return jsonify({
        "channel": CHANNELS[channel_id],
        "schedule": schedule
    })


@channels_bp.route('/api/epg', methods=['GET'])
def get_full_epg():
    """
    GET /api/epg
    Returns: Full TV guide for all channels
    """
    epg = {}
    
    for channel_id in CHANNELS:
        epg[channel_id] = {
            "channel": CHANNELS[channel_id],
            "schedule": generate_epg_for_channel(channel_id, hours=6)
        }
    
    return jsonify(epg)
